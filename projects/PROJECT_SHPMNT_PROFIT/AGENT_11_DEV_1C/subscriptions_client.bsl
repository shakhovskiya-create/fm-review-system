// Подписка на событие: ekf_ПриЗаписиКонтрагента
// Источник: Справочник.Контрагенты
// Событие: ПриЗаписи
//
// Генерирует событие: "client.updated" (1c.client.updated.v1)
//
// ТЗ: docs/tz-1c-kafka-integration.md, секция 3.7
// Задача: EKFLAB-518
// Автор: Шаховский А.С.
// Изменения: EKFLAB-522 — HIGH-004 (функциональная опция)

// Обработчик подписки ПриЗаписи справочника "Контрагенты".
// Определяет что именно изменилось и отправляет событие с полем "changes".
//
// Параметры:
//  Источник - СправочникОбъект.Контрагенты - записываемый контрагент
//  Отказ    - Булево - флаг отказа от записи
//
Процедура ПриЗаписиКонтрагента(Источник, Отказ) Экспорт

    // Не отправлять при отказе
    Если Отказ Тогда
        Возврат;
    КонецЕсли;

    // HIGH-004: Проверка функциональной опции (привязана к kill switch)
    Если НЕ ПолучитьФункциональнуюОпцию("ekf_ИнтеграцияРентабельности") Тогда
        Возврат;
    КонецЕсли;

    // Не отправлять для новых контрагентов (только обновления)
    Если Источник.ЭтоНовый() Тогда
        Возврат;
    КонецЕсли;

    // Определяем что изменилось
    СтруктураИзменений = ОпределитьИзмененияКонтрагента(Источник);

    // Если ничего релевантного не изменилось — не отправлять
    Если СтруктураИзменений.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    // Формируем и отправляем событие
    ДанныеСобытия = ekf_ИнтеграцияСервер.СформироватьДанныеКлиента(Источник, СтруктураИзменений);
    ekf_ИнтеграцияСервер.ОтправитьСобытие("client.updated", ДанныеСобытия);

КонецПроцедуры

// Определяет какие поля контрагента изменились.
// По ТЗ в "changes" передаются только те поля, которые действительно изменились.
//
// Параметры:
//  Источник - СправочникОбъект.Контрагенты - записываемый контрагент
//
// Возвращаемое значение:
//  Структура - только изменившиеся поля (ключ = имя поля, значение = новое значение)
//
Функция ОпределитьИзмененияКонтрагента(Источник)

    Изменения = Новый Структура;

    Попытка
        // Читаем сохраненную версию из базы
        СсылкаНаЭлемент = Источник.Ссылка;
        Если НЕ ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
            Возврат Изменения;
        КонецЕсли;

        Запрос = Новый Запрос;
        Запрос.Текст =
            "ВЫБРАТЬ
            |   Контр.Наименование КАК Наименование,
            |   Контр.Ответственный КАК Ответственный
            |ИЗ
            |   Справочник.Контрагенты КАК Контр
            |ГДЕ
            |   Контр.Ссылка = &Ссылка";
        Запрос.УстановитьПараметр("Ссылка", СсылкаНаЭлемент);

        Результат = Запрос.Выполнить();
        Если Результат.Пустой() Тогда
            Возврат Изменения;
        КонецЕсли;

        Выборка = Результат.Выбрать();
        Выборка.Следующий();

        // Сравниваем наименование
        Если Строка(Источник) <> Выборка.Наименование Тогда
            Изменения.Вставить("name", Строка(Источник));
        КонецЕсли;

        // Сравниваем ответственного (менеджера)
        Если Источник.Ответственный <> Выборка.Ответственный Тогда
            Если ЗначениеЗаполнено(Источник.Ответственный) Тогда
                Изменения.Вставить("manager_id", Строка(Источник.Ответственный.УникальныйИдентификатор()));
            Иначе
                Изменения.Вставить("manager_id", "");
            КонецЕсли;
        КонецЕсли;

        // Проверяем доп. реквизиты расширения (стратегический клиент, допустимое отклонение)
        Попытка
            // is_strategic
            НовоеЗначение = Источник.ekf_СтратегическийКлиент;
            СтароеЗначение = СсылкаНаЭлемент.ekf_СтратегическийКлиент;
            Если НовоеЗначение <> СтароеЗначение Тогда
                Изменения.Вставить("is_strategic", НовоеЗначение);
            КонецЕсли;
        Исключение
            // Реквизит может отсутствовать
        КонецПопытки;

        Попытка
            // allowed_deviation — строка, не число (по ТЗ)
            НовоеОтклонение = Источник.ekf_ДопустимоеОтклонение;
            СтароеОтклонение = СсылкаНаЭлемент.ekf_ДопустимоеОтклонение;
            Если НовоеОтклонение <> СтароеОтклонение Тогда
                Изменения.Вставить("allowed_deviation", Строка(НовоеОтклонение));
            КонецЕсли;
        Исключение
            // Реквизит может отсутствовать
        КонецПопытки;

    Исключение
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.ОпределениеИзменений",
            УровеньЖурналаРегистрации.Предупреждение, , ,
            СтрШаблон("Ошибка определения изменений контрагента: %1",
                ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
    КонецПопытки;

    Возврат Изменения;

КонецФункции
