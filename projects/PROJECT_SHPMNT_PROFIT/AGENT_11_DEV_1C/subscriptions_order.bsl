// Подписка на событие: ekf_ПриЗаписиЗаказаПокупателя
// Источник: Документ.ЗаказПокупателя
// Событие: ПриЗаписи
//
// Генерирует события:
//   - "order.created" (1c.order.created.v1) — новый заказ
//   - "order.updated" (1c.order.updated.v1) — обновление существующего заказа
//
// ТЗ: docs/tz-1c-kafka-integration.md, секции 3.1, 3.2
// Задача: EKFLAB-518
// Автор: Шаховский А.С.
// Изменения: EKFLAB-522 — HIGH-004 (функциональная опция)

// Обработчик подписки ПриЗаписи документа "Заказ покупателя".
// Определяет тип события (created/updated) и отправляет в NiFi -> Kafka.
//
// Параметры:
//  Источник - ДокументОбъект.ЗаказПокупателя - записываемый документ
//  Отказ    - Булево - флаг отказа от записи
//
Процедура ПриЗаписиЗаказаПокупателя(Источник, Отказ) Экспорт

    // Не отправлять событие, если запись уже отменена другой логикой
    Если Отказ Тогда
        Возврат;
    КонецЕсли;

    // HIGH-004: Проверка функциональной опции (привязана к kill switch)
    Если НЕ ПолучитьФункциональнуюОпцию("ekf_ИнтеграцияРентабельности") Тогда
        Возврат;
    КонецЕсли;

    // Определяем тип события: создание или обновление
    Если Источник.ЭтоНовый() Тогда

        // Новый заказ — order.created
        ДанныеСобытия = ekf_ИнтеграцияСервер.СформироватьДанныеЗаказаСоздан(Источник);
        ekf_ИнтеграцияСервер.ОтправитьСобытие("order.created", ДанныеСобытия);

    Иначе

        // Существующий заказ — order.updated
        // Определяем какие поля изменились
        МассивИзменений = ОпределитьИзмененияЗаказа(Источник);

        Если МассивИзменений.Количество() > 0 Тогда
            ДанныеСобытия = ekf_ИнтеграцияСервер.СформироватьДанныеЗаказаОбновлен(Источник, МассивИзменений);
            ekf_ИнтеграцияСервер.ОтправитьСобытие("order.updated", ДанныеСобытия);
        КонецЕсли;

    КонецЕсли;

КонецПроцедуры

// Определяет список изменившихся полей заказа для поля "changes" в JSON.
// Сравнивает текущие значения объекта с сохраненными в базе.
//
// Параметры:
//  Источник - ДокументОбъект.ЗаказПокупателя - записываемый документ
//
// Возвращаемое значение:
//  Массив - список строк с именами изменившихся полей
//
Функция ОпределитьИзмененияЗаказа(Источник)

    МассивИзменений = Новый Массив;

    Попытка
        // Читаем ранее сохранённую версию из базы
        СсылкаНаДок = Источник.Ссылка;
        Если НЕ ЗначениеЗаполнено(СсылкаНаДок) Тогда
            МассивИзменений.Добавить("new_document");
            Возврат МассивИзменений;
        КонецЕсли;

        Запрос = Новый Запрос;
        Запрос.Текст =
            "ВЫБРАТЬ
            |   Заказ.СуммаДокумента КАК СуммаДокумента,
            |   Заказ.Контрагент КАК Контрагент,
            |   Заказ.Проведен КАК Проведен
            |ИЗ
            |   Документ.ЗаказПокупателя КАК Заказ
            |ГДЕ
            |   Заказ.Ссылка = &Ссылка";
        Запрос.УстановитьПараметр("Ссылка", СсылкаНаДок);

        Результат = Запрос.Выполнить();
        Если Результат.Пустой() Тогда
            МассивИзменений.Добавить("new_document");
            Возврат МассивИзменений;
        КонецЕсли;

        Выборка = Результат.Выбрать();
        Выборка.Следующий();

        // Сравниваем ключевые поля
        Если Источник.СуммаДокумента <> Выборка.СуммаДокумента Тогда
            МассивИзменений.Добавить("total_amount");
            МассивИзменений.Добавить("line_items");
        КонецЕсли;

        Если Источник.Контрагент <> Выборка.Контрагент Тогда
            МассивИзменений.Добавить("client");
        КонецЕсли;

        Если Источник.Проведен <> Выборка.Проведен Тогда
            МассивИзменений.Добавить("status");
        КонецЕсли;

    Исключение
        // При любой ошибке считаем что всё изменилось
        МассивИзменений.Добавить("status");
        МассивИзменений.Добавить("line_items");
        МассивИзменений.Добавить("total_amount");
    КонецПопытки;

    // Если ничего конкретного не нашли, но документ перезаписывается — отправляем общее обновление
    Если МассивИзменений.Количество() = 0 Тогда
        МассивИзменений.Добавить("status");
    КонецЕсли;

    Возврат МассивИзменений;

КонецФункции
