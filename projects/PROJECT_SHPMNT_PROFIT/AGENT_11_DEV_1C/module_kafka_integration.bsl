//  СтруктураИзменений - Структура - только изменившиеся поля (is_strategic, allowed_deviation, и т.д.)
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеКлиента(КонтрагентОбъект, СтруктураИзменений) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "client.updated");
    Данные.Вставить("source",             "1c-ut-10.2");
    Данные.Вставить("occurred_at",        ФорматДатыISO(ТекущаяДатаСеанса()));

    // external_id = ИНН/КПП
    ИНН = СокрЛП(КонтрагентОбъект.ИНН);
