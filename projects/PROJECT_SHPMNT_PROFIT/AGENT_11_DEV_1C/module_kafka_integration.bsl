//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаказПокупателя - заказ
//
// Возвращаемое значение:
//  Строка - "manual" или "edi"
//
Функция ОпределитьИсточникЗаказа(ДокументОбъект)

    // В УТ 10.2 признак EDI может определяться через:
    // 1. Доп. реквизит документа (если настроен)
    // 2. Вид заказа
    // 3. Комментарий
    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.ВидЗаказа)
            И Строка(ДокументОбъект.ВидЗаказа) = "EDI" Тогда
            Возврат "edi";
        КонецЕсли;
    Исключение
        // Реквизит ВидЗаказа может отсутствовать
    КонецПопытки;

    Возврат "manual";

КонецФункции

// Получает UUID листа согласования из заказа покупателя.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаказПокупателя - заказ
//
// Возвращаемое значение:
//  Строка - UUID ЛС или пустая строка
//
Функция ПолучитьИдЛС(ДокументОбъект)

    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.ЛокальнаяСмета) Тогда
            Возврат Строка(ДокументОбъект.ЛокальнаяСмета.УникальныйИдентификатор());
        КонецЕсли;
    Исключение
        // Реквизит ЛокальнаяСмета может отсутствовать в типовой конфигурации
    КонецПопытки;

    Возврат "";

КонецФункции

// Получает UUID ЛС из документа реализации (через связанный заказ).
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.РеализацияТоваровИУслуг - отгрузка
//
// Возвращаемое значение:
//  Строка - UUID ЛС или пустая строка
//
Функция ПолучитьИдЛСИзЗаказа(ДокументОбъект)

    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.ЗаказПокупателя)
            И ЗначениеЗаполнено(ДокументОбъект.ЗаказПокупателя.ЛокальнаяСмета) Тогда
            Возврат Строка(ДокументОбъект.ЗаказПокупателя.ЛокальнаяСмета.УникальныйИдентификатор());
        КонецЕсли;
    Исключение
        // Реквизит может отсутствовать
    КонецПопытки;

    Возврат "";

КонецФункции

// Получает UUID ЛС из документа возврата (через документ-основание).
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ВозвратТоваровОтПокупателя - возврат
//
// Возвращаемое значение:
//  Строка - UUID ЛС или пустая строка
//
Функция ПолучитьИдЛСИзВозврата(ДокументОбъект)

    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.ДокументОснование)
            И ТипЗнч(ДокументОбъект.ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя")
            И ЗначениеЗаполнено(ДокументОбъект.ДокументОснование.ЛокальнаяСмета) Тогда
            Возврат Строка(ДокументОбъект.ДокументОснование.ЛокальнаяСмета.УникальныйИдентификатор());
        КонецЕсли;
    Исключение
        // Реквизит может отсутствовать
    КонецПопытки;

    Возврат "";

КонецФункции

// Разбирает URL строку на компоненты (хост, порт, путь).
//
// Параметры:
//  URLСтрока - Строка - полный URL (например "https://nifi.internal:8443/api/v1/events")
//
// Возвращаемое значение:
//  Структура - Хост (Строка), Порт (Число), Путь (Строка)
//
Функция РазобратьURL(URLСтрока)

    Результат = Новый Структура("Хост, Порт, Путь", "", 443, "");

    РабочаяСтрока = URLСтрока;

    // Убираем протокол
    Если Лев(РабочаяСтрока, 8) = "https://" Тогда
        РабочаяСтрока = Сред(РабочаяСтрока, 9);
        Результат.Порт = 443;
    ИначеЕсли Лев(РабочаяСтрока, 7) = "http://" Тогда
        РабочаяСтрока = Сред(РабочаяСтрока, 8);
        Результат.Порт = 80;
    КонецЕсли;

    // Отделяем путь
    ПозицияСлеш = СтрНайти(РабочаяСтрока, "/");
    Если ПозицияСлеш > 0 Тогда
        Результат.Путь = Сред(РабочаяСтрока, ПозицияСлеш);
        РабочаяСтрока = Лев(РабочаяСтрока, ПозицияСлеш - 1);
    КонецЕсли;

    // Отделяем порт
    ПозицияДвоеточие = СтрНайти(РабочаяСтрока, ":");
    Если ПозицияДвоеточие > 0 Тогда
        Результат.Хост = Лев(РабочаяСтрока, ПозицияДвоеточие - 1);
        Результат.Порт = Число(Сред(РабочаяСтрока, ПозицияДвоеточие + 1));
    Иначе
        Результат.Хост = РабочаяСтрока;
    КонецЕсли;

    Возврат Результат;

КонецФункции

#КонецОбласти
