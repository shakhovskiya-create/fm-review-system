// Общий модуль: ekf_ИнтеграцияСервер
// Контекст: Сервер
//
// Назначение: формирование и отправка событий в NiFi (NiFi -> Kafka).
// Обработка 9 исходящих типов событий по ТЗ: docs/tz-1c-kafka-integration.md
// Транспорт: HTTP POST -> NiFi -> Kafka
// Kafka headers: X-Message-Id, X-Correlation-Id (маппятся NiFi в Kafka headers)
//
// Автор: Шаховский А.С.
// Дата: 13.03.2026
// Задача: EKFLAB-518
// Изменения: EKFLAB-522 — HIGH-001 (перечисление статусов), HIGH-002 (кешированные настройки),
//            HIGH-004 (функциональная опция)

#Область ПрограммныйИнтерфейс

// Отправляет событие в NiFi.
// При неудаче записывает в очередь повторной отправки (ekf_ОчередьОтправкиСобытий).
// Не блокирует UI: таймаут HTTP настраивается (по умолчанию 5 сек).
//
// Параметры:
//  ТипСобытия    - Строка - тип события (например "order.created")
//  ДанныеСобытия - Структура - payload события, уже содержит все поля по схеме ТЗ
//  ИдКорреляции  - Строка - UUID корреляции (необязательный, если пуст - генерируется новый)
//
Процедура ОтправитьСобытие(ТипСобытия, ДанныеСобытия, ИдКорреляции = "") Экспорт

    // Проверка kill switch (через кешированный модуль, HIGH-002)
    Если НЕ ekf_ИнтеграцияНастройкиПовтИспСервер.ИнтеграцияАктивна() Тогда
        Возврат;
    КонецЕсли;

    ИдентификаторСообщения = Строка(Новый УникальныйИдентификатор); // message_id

    Если НЕ ЗначениеЗаполнено(ИдКорреляции) Тогда
        ИдКорреляции = Строка(Новый УникальныйИдентификатор);
    КонецЕсли;

    // event_id внутри payload (по ТЗ — поле верхнего уровня JSON)
    // ДанныеСобытия уже содержит event_id, event_type, source, occurred_at и пр.
    ТелоJSON = СтруктуруВJSON(ДанныеСобытия);

    Топик = ОпределитьТопик(ТипСобытия);

    Попытка
        КодОтвета = ОтправитьHTTPВNiFi(ТелоJSON, ИдентификаторСообщения, ИдКорреляции);

        Если КодОтвета = 200 ИЛИ КодОтвета = 202 ИЛИ КодОтвета = 409 Тогда
            // Успех или дубликат
            Если ekf_ИнтеграцияНастройкиПовтИспСервер.ЛогированиеПодробное() Тогда
                ЗаписьЖурналаРегистрации(
                    "ekf_Интеграция.ОтправкаСобытия",
                    УровеньЖурналаРегистрации.Информация, , ,
                    СтрШаблон("Событие отправлено: тип=%1, id=%2, HTTP %3",
                        ТипСобытия, ИдентификаторСообщения, КодОтвета));
            КонецЕсли;
            Возврат;
        ИначеЕсли КодОтвета = 400 Тогда
            // Невалидный payload — permanent failure, не повторять
            ЗаписьЖурналаРегистрации(
                "ekf_Интеграция.ОтправкаСобытия",
                УровеньЖурналаРегистрации.Ошибка, , ,
                СтрШаблон("Невалидный payload: тип=%1, HTTP 400, id=%2",
                    ТипСобытия, ИдентификаторСообщения));
            Возврат;
        Иначе
            // Любой другой код — записать в очередь
            ПоместитьВОчередь(ИдентификаторСообщения, ТипСобытия, Топик, ТелоJSON, ИдКорреляции, КодОтвета, "");
        КонецЕсли;
    Исключение
        // Сетевая ошибка (NiFi недоступен, таймаут)
        ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.ОтправкаСобытия",
            УровеньЖурналаРегистрации.Предупреждение, , ,
            СтрШаблон("Сетевая ошибка: тип=%1, id=%2. %3",
                ТипСобытия, ИдентификаторСообщения, ТекстОшибки));

        ПоместитьВОчередь(ИдентификаторСообщения, ТипСобытия, Топик, ТелоJSON, ИдКорреляции, 0, ТекстОшибки);
    КонецПопытки;

КонецПроцедуры

// Помещает событие в очередь повторной отправки БЕЗ попытки HTTP-отправки.
// HIGH-003: Используется подписками ОбработкаПроведения (реализация, возврат),
// чтобы не выполнять HTTP-вызов внутри транзакции проведения документа.
// HTTP-отправка выполняется фоновым заданием ekf_ОбработкаОчередиОтправки.
//
// Параметры:
//  ТипСобытия    - Строка - тип события (например "shipment.posted")
//  ДанныеСобытия - Структура - payload события, уже содержит все поля по схеме ТЗ
//  ИдКорреляции  - Строка - UUID корреляции (необязательный)
//
Процедура ПоместитьСобытиеВОчередь(ТипСобытия, ДанныеСобытия, ИдКорреляции = "") Экспорт

    // Проверка kill switch (через кешированный модуль, HIGH-002)
    Если НЕ ekf_ИнтеграцияНастройкиПовтИспСервер.ИнтеграцияАктивна() Тогда
        Возврат;
    КонецЕсли;

    ИдентификаторСообщения = Строка(Новый УникальныйИдентификатор);

    Если НЕ ЗначениеЗаполнено(ИдКорреляции) Тогда
        ИдКорреляции = Строка(Новый УникальныйИдентификатор);
    КонецЕсли;

    ТелоJSON = СтруктуруВJSON(ДанныеСобытия);
    Топик = ОпределитьТопик(ТипСобытия);

    ПоместитьВОчередь(ИдентификаторСообщения, ТипСобытия, Топик, ТелоJSON, ИдКорреляции, 0, "");

    Если ekf_ИнтеграцияНастройкиПовтИспСервер.ЛогированиеПодробное() Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.ОчередьСобытий",
            УровеньЖурналаРегистрации.Информация, , ,
            СтрШаблон("Событие помещено в очередь (без HTTP): тип=%1, id=%2",
                ТипСобытия, ИдентификаторСообщения));
    КонецЕсли;

КонецПроцедуры

// Формирует данные события "Заказ создан" (order.created) по схеме ТЗ 3.1.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаказПокупателя - записываемый документ
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации (точно по схеме ТЗ)
//
Функция СформироватьДанныеЗаказаСоздан(ДокументОбъект) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "order.created");
    Данные.Вставить("source",             "1c-ut-10.2");
    Данные.Вставить("occurred_at",        ФорматДатыISO(ТекущаяДатаСеанса()));
    Данные.Вставить("external_id",        СокрЛП(ДокументОбъект.Номер));
    Данные.Вставить("client_id",          Строка(ДокументОбъект.Контрагент.УникальныйИдентификатор()));
    Данные.Вставить("client_name",        Строка(ДокументОбъект.Контрагент));
    Данные.Вставить("manager_id",         ПолучитьИдОтветственного(ДокументОбъект));
    Данные.Вставить("manager_name",       Строка(ДокументОбъект.Ответственный));

    // priority по ТЗ: P1 если сумма > 500 000 руб, иначе P2
    Если ДокументОбъект.СуммаДокумента > 500000 Тогда
        Данные.Вставить("priority", "P1");
    Иначе
        Данные.Вставить("priority", "P2");
    КонецЕсли;

    // source_1c: manual или edi
    Данные.Вставить("source_1c", ОпределитьИсточникЗаказа(ДокументОбъект));

    // local_estimate_id (ЛС)
    Данные.Вставить("local_estimate_id", ПолучитьИдЛС(ДокументОбъект));

    // line_items
    МассивСтрок = Новый Массив;
    Для Каждого СтрокаТовара Из ДокументОбъект.Товары Цикл
        СтруктураСтроки = Новый Структура;
        СтруктураСтроки.Вставить("product_id",    Строка(СтрокаТовара.Номенклатура.УникальныйИдентификатор()));
        СтруктураСтроки.Вставить("product_name",  Строка(СтрокаТовара.Номенклатура));
        СтруктураСтроки.Вставить("quantity",       ФорматЧисла(СтрокаТовара.Количество, 0));
        СтруктураСтроки.Вставить("price",          ФорматСуммы(СтрокаТовара.Цена));
        СтруктураСтроки.Вставить("amount",         ФорматСуммы(СтрокаТовара.Сумма));
        МассивСтрок.Добавить(СтруктураСтроки);
    КонецЦикла;
    Данные.Вставить("line_items", МассивСтрок);

    Данные.Вставить("total_amount", ФорматСуммы(ДокументОбъект.СуммаДокумента));

    Возврат Данные;

КонецФункции

// Формирует данные события "Заказ обновлен" (order.updated) по схеме ТЗ 3.2.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаказПокупателя - записываемый документ
//  МассивИзменений - Массив - список изменившихся полей (Строка[])
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеЗаказаОбновлен(ДокументОбъект, МассивИзменений) Экспорт

    Данные = СформироватьДанныеЗаказаСоздан(ДокументОбъект);
    Данные.event_type = "order.updated";
    Данные.event_id   = Строка(Новый УникальныйИдентификатор);
    Данные.Вставить("changes", МассивИзменений);

    Возврат Данные;

КонецФункции

// Формирует данные события "Отгрузка проведена" (shipment.posted) по схеме ТЗ 3.3.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.РеализацияТоваровИУслуг - проводимый документ
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеОтгрузки(ДокументОбъект) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "shipment.posted");
    Данные.Вставить("source",             "1c-ut-10.2");
    Данные.Вставить("occurred_at",        ФорматДатыISO(ТекущаяДатаСеанса()));
    Данные.Вставить("external_id",        СокрЛП(ДокументОбъект.Номер));
    Данные.Вставить("client_id",          Строка(ДокументОбъект.Контрагент.УникальныйИдентификатор()));
    Данные.Вставить("manager_id",         ПолучитьИдОтветственного(ДокументОбъект));

    // Связанный заказ покупателя
    Если ЗначениеЗаполнено(ДокументОбъект.ЗаказПокупателя) Тогда
        Данные.Вставить("order_id", Строка(ДокументОбъект.ЗаказПокупателя.УникальныйИдентификатор()));
    Иначе
        Данные.Вставить("order_id", "");
    КонецЕсли;

    // ЛС (из связанного заказа)
    Данные.Вставить("local_estimate_id", ПолучитьИдЛСИзЗаказа(ДокументОбъект));

    // line_items с npss
    МассивСтрок = Новый Массив;
    Для Каждого СтрокаТовара Из ДокументОбъект.Товары Цикл
        СтруктураСтроки = Новый Структура;
        СтруктураСтроки.Вставить("product_id",    Строка(СтрокаТовара.Номенклатура.УникальныйИдентификатор()));
        СтруктураСтроки.Вставить("product_name",  Строка(СтрокаТовара.Номенклатура));
        СтруктураСтроки.Вставить("quantity",       ФорматЧисла(СтрокаТовара.Количество, 0));
        СтруктураСтроки.Вставить("price",          ФорматСуммы(СтрокаТовара.Цена));
        СтруктураСтроки.Вставить("amount",         ФорматСуммы(СтрокаТовара.Сумма));

        // НПСС фиксируется в момент отгрузки
        НПСС = ПолучитьНПСС(СтрокаТовара.Номенклатура, ДокументОбъект.Дата);
        СтруктураСтроки.Вставить("npss", ФорматСуммы(НПСС));

        МассивСтрок.Добавить(СтруктураСтроки);
    КонецЦикла;
    Данные.Вставить("line_items", МассивСтрок);

    Данные.Вставить("total_amount", ФорматСуммы(ДокументОбъект.СуммаДокумента));

    Возврат Данные;

КонецФункции

// Формирует данные события "Возврат отгрузки" (shipment.returned) по схеме ТЗ 3.4.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ВозвратТоваровОтПокупателя - проводимый документ
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеВозврата(ДокументОбъект) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "shipment.returned");
    Данные.Вставить("source",             "1c-ut-10.2");
    Данные.Вставить("occurred_at",        ФорматДатыISO(ТекущаяДатаСеанса()));
    Данные.Вставить("external_id",        СокрЛП(ДокументОбъект.Номер));
    Данные.Вставить("client_id",          Строка(ДокументОбъект.Контрагент.УникальныйИдентификатор()));
    Данные.Вставить("manager_id",         ПолучитьИдОтветственного(ДокументОбъект));

    // Связанный заказ (через документ-основание)
    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.ДокументОснование)
            И ТипЗнч(ДокументОбъект.ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
            Данные.Вставить("order_id", Строка(ДокументОбъект.ДокументОснование.УникальныйИдентификатор()));
        Иначе
            Данные.Вставить("order_id", "");
        КонецЕсли;
    Исключение
        Данные.Вставить("order_id", "");
    КонецПопытки;

    Данные.Вставить("local_estimate_id", ПолучитьИдЛСИзВозврата(ДокументОбъект));

    // line_items с npss
    МассивСтрок = Новый Массив;
    Для Каждого СтрокаТовара Из ДокументОбъект.Товары Цикл
        СтруктураСтроки = Новый Структура;
        СтруктураСтроки.Вставить("product_id",    Строка(СтрокаТовара.Номенклатура.УникальныйИдентификатор()));
        СтруктураСтроки.Вставить("product_name",  Строка(СтрокаТовара.Номенклатура));
        СтруктураСтроки.Вставить("quantity",       ФорматЧисла(СтрокаТовара.Количество, 0));
        СтруктураСтроки.Вставить("price",          ФорматСуммы(СтрокаТовара.Цена));
        СтруктураСтроки.Вставить("amount",         ФорматСуммы(СтрокаТовара.Сумма));

        НПСС = ПолучитьНПСС(СтрокаТовара.Номенклатура, ДокументОбъект.Дата);
        СтруктураСтроки.Вставить("npss", ФорматСуммы(НПСС));

        МассивСтрок.Добавить(СтруктураСтроки);
    КонецЦикла;
    Данные.Вставить("line_items", МассивСтрок);

    Данные.Вставить("total_amount", ФорматСуммы(ДокументОбъект.СуммаДокумента));

    Возврат Данные;

КонецФункции

// Формирует данные события "Обновление НПСС" (price.npss-updated) по схеме ТЗ 3.5.
//
// Параметры:
//  Номенклатура   - СправочникСсылка.Номенклатура - товар
//  СтараяНПСС     - Число - предыдущее значение НПСС
//  НоваяНПСС      - Число - новое значение НПСС
//  ЦенаЗакупки    - Число - закупочная цена
//  ЗатратыЛогистика - Число - логистические затраты
//  ЗатратыНакладные - Число - накладные расходы
//  МетодРасчета   - Строка - "weighted_average" и т.п.
//  Триггер        - Строка - "planned" / "exchange_rate" / "purchase_price"
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеНПСС(Номенклатура, СтараяНПСС, НоваяНПСС,
        ЦенаЗакупки, ЗатратыЛогистика, ЗатратыНакладные,
        МетодРасчета, Триггер) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "price.npss-updated");
    Данные.Вставить("source",             "1c-ut-10.2");
    Данные.Вставить("occurred_at",        ФорматДатыISO(ТекущаяДатаСеанса()));
    Данные.Вставить("product_id",         Строка(Номенклатура.УникальныйИдентификатор()));
    Данные.Вставить("product_name",       Строка(Номенклатура));
    Данные.Вставить("old_npss",           ФорматСуммы(СтараяНПСС));
    Данные.Вставить("new_npss",           ФорматСуммы(НоваяНПСС));
    Данные.Вставить("purchase_price",     ФорматСуммы(ЦенаЗакупки));
    Данные.Вставить("logistics_cost",     ФорматСуммы(ЗатратыЛогистика));
    Данные.Вставить("overhead_cost",      ФорматСуммы(ЗатратыНакладные));
    Данные.Вставить("method",             МетодРасчета);
    Данные.Вставить("trigger",            Триггер);

    Возврат Данные;

КонецФункции

// Формирует данные события "Изменение закупочной цены" (price.purchase-changed) по схеме ТЗ 3.6.
//
// Параметры:
//  Номенклатура   - СправочникСсылка.Номенклатура - товар
//  СтараяЦена     - Число - предыдущая закупочная цена
//  НоваяЦена      - Число - новая закупочная цена
//  Поставщик      - Строка - наименование поставщика
//  ДатаДействия   - Дата - дата начала действия новой цены
//
// Возвращаемое значение:
//  Структура - данные для JSON-сериализации
//
Функция СформироватьДанныеЗакупочнойЦены(Номенклатура, СтараяЦена, НоваяЦена,
        Поставщик, ДатаДействия) Экспорт

    Данные = Новый Структура;
    Данные.Вставить("event_id",           Строка(Новый УникальныйИдентификатор));
    Данные.Вставить("event_type",         "price.purchase-changed");
    Данные.Вставить("source",             "1c-ut-10.2");
