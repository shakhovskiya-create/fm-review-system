// Рассчитывает время следующей попытки по экспоненциальному backoff.
//
// Параметры:
//  НомерПопытки - Число - текущий номер попытки
//
// Возвращаемое значение:
//  Дата - дата и время следующей попытки
//
Функция РассчитатьСледующуюПопытку(НомерПопытки) Экспорт

    Если НомерПопытки <= 1 Тогда
        ЗадержкаСекунд = 30;
    ИначеЕсли НомерПопытки = 2 Тогда
        ЗадержкаСекунд = 60;
    ИначеЕсли НомерПопытки = 3 Тогда
        ЗадержкаСекунд = 120;
    ИначеЕсли НомерПопытки = 4 Тогда
        ЗадержкаСекунд = 300;
    ИначеЕсли НомерПопытки = 5 Тогда
        ЗадержкаСекунд = 600;
    ИначеЕсли НомерПопытки <= 10 Тогда
        ЗадержкаСекунд = 900;
    ИначеЕсли НомерПопытки <= 20 Тогда
        ЗадержкаСекунд = 1800;
    ИначеЕсли НомерПопытки <= 50 Тогда
        ЗадержкаСекунд = 3600;
    Иначе
        ЗадержкаСекунд = 7200;
    КонецЕсли;

    Возврат ТекущаяДатаСеанса() + ЗадержкаСекунд;

КонецФункции

// Получает НПСС для номенклатуры на дату.
// НПСС хранится в регистре сведений ЦеныНоменклатуры (или аналог в конфигурации).
//
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура - товар
//  ДатаСреза    - Дата - дата для среза последних
//
// Возвращаемое значение:
//  Число - значение НПСС (0 если не найдено)
//
Функция ПолучитьНПСС(Номенклатура, ДатаСреза)

    // В УТ 10.2 НПСС может храниться в регистре сведений "ЦеныНоменклатуры"
    // с видом цены "НПСС" (или аналогичном). Конкретное имя вида цены
    // зависит от настроек конкретной базы.
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   ЦеныСрез.Цена КАК Цена
        |ИЗ
        |   РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, Номенклатура = &Номенклатура
        |       И ТипЦен = &ТипЦен) КАК ЦеныСрез";
    Запрос.УстановитьПараметр("Дата",         ДатаСреза);
    Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

    // Поиск типа цен НПСС
    Попытка
        ТипЦенНПСС = Справочники.ТипыЦенНоменклатуры.НайтиПоНаименованию("НПСС");
        Запрос.УстановитьПараметр("ТипЦен", ТипЦенНПСС);
    Исключение
        Возврат 0;
    КонецПопытки;

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Цена;
    КонецЕсли;

    Возврат 0;

КонецФункции

