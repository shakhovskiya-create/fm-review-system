// Отправляет событие из очереди повторной отправки.
// Используется фоновым заданием (ekf_ИнтеграцияФоновые.ОбработатьОчередьОтправки).
//
// Параметры:
//  ИдентификаторСообщения - Строка - UUID сообщения
//  ТелоJSON               - Строка - сериализованный JSON
//  ИдКорреляции           - Строка - UUID корреляции
//
// Возвращаемое значение:
//  Булево - Истина, если отправка успешна
//
Функция ОтправитьИзОчереди(ИдентификаторСообщения, ТелоJSON, ИдКорреляции) Экспорт

    Попытка
        КодОтвета = ОтправитьHTTPВNiFi(ТелоJSON, ИдентификаторСообщения, ИдКорреляции);

        Если КодОтвета = 200 ИЛИ КодОтвета = 202 ИЛИ КодОтвета = 409 Тогда
            Возврат Истина;
        ИначеЕсли КодОтвета = 400 Тогда
            // Permanent failure — удаляем как невалидный
            ЗаписьЖурналаРегистрации(
                "ekf_Интеграция.ПовторнаяОтправка",
                УровеньЖурналаРегистрации.Ошибка, , ,
                СтрШаблон("Невалидный payload (HTTP 400), удаляем: id=%1", ИдентификаторСообщения));
            Возврат Истина;
        Иначе
            Возврат Ложь;
        КонецЕсли;
    Исключение
        Возврат Ложь;
    КонецПопытки;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет HTTP POST запрос к NiFi.
//
// Параметры:
//  ТелоJSON               - Строка - JSON payload
//  ИдентификаторСообщения - Строка - UUID для заголовка X-Message-Id
//  ИдКорреляции           - Строка - UUID для заголовка X-Correlation-Id
//
// Возвращаемое значение:
//  Число - HTTP-код ответа
//
Функция ОтправитьHTTPВNiFi(ТелоJSON, ИдентификаторСообщения, ИдКорреляции)

    // HIGH-002: Чтение настроек через кешированный модуль (ПовторногоИспользования = ВызовахСеанса)
    АдресNiFi   = ekf_ИнтеграцияНастройкиПовтИспСервер.АдресNiFi();
    APIКлюч     = ekf_ИнтеграцияНастройкиПовтИспСервер.APIКлючNiFi();
    ТаймаутHTTP = ekf_ИнтеграцияНастройкиПовтИспСервер.ТаймаутHTTP();

    Если НЕ ЗначениеЗаполнено(АдресNiFi) ИЛИ НЕ ЗначениеЗаполнено(APIКлюч) Тогда
        ВызватьИсключение "Не заполнены настройки интеграции (ekf_ИнтеграцияNiFiURL / ekf_ИнтеграцияNiFiAPIКлюч)";
    КонецЕсли;

    // Разбор URL: извлекаем хост, порт, путь
    СтруктураURL = РазобратьURL(АдресNiFi);

    // Защищенное соединение (HTTPS)
    ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();

    Соединение = Новый HTTPСоединение(
        СтруктураURL.Хост,
        СтруктураURL.Порт,
        , ,                        // логин/пароль не используются
        , ТаймаутHTTP,
        ЗащищенноеСоединение);

    Заголовки = Новый Соответствие;
    Заголовки.Вставить("Content-Type",     "application/json; charset=utf-8");
    Заголовки.Вставить("X-Api-Key",        APIКлюч);
    Заголовки.Вставить("X-Message-Id",     ИдентификаторСообщения);
    Заголовки.Вставить("X-Correlation-Id", ИдКорреляции);

    ПутьЗапроса = СтруктураURL.Путь;
    Если НЕ ЗначениеЗаполнено(ПутьЗапроса) Тогда
        ПутьЗапроса = "/api/v1/events";
    КонецЕсли;

    Запрос = Новый HTTPЗапрос(ПутьЗапроса, Заголовки);
    Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

    Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);

    Возврат Ответ.КодСостояния;

КонецФункции

// Помещает событие в очередь повторной отправки.
//
// Параметры:
//  ИдентификаторСообщения - Строка - UUID сообщения
//  ТипСобытия             - Строка - тип события
//  Топик                  - Строка - целевой топик Kafka
//  ТелоJSON               - Строка - сериализованный JSON
//  ИдКорреляции           - Строка - UUID корреляции
//  КодОшибки              - Число - HTTP-код ответа (0 = сетевая ошибка)
//  ТекстОшибки            - Строка - описание ошибки
//
Процедура ПоместитьВОчередь(ИдентификаторСообщения, ТипСобытия, Топик,
        ТелоJSON, ИдКорреляции, КодОшибки, ТекстОшибки)

    МенеджерЗаписи = РегистрыСведений.ekf_ОчередьОтправкиСобытий.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторСообщения = Новый УникальныйИдентификатор(ИдентификаторСообщения);
    МенеджерЗаписи.ТипСобытия             = ТипСобытия;
    МенеджерЗаписи.Топик                  = Топик;
    МенеджерЗаписи.ТелоСообщения          = Новый ХранилищеЗначения(ТелоJSON);
    МенеджерЗаписи.ИдКорреляции           = ИдКорреляции;
    МенеджерЗаписи.ДатаСоздания           = ТекущаяДатаСеанса();
    МенеджерЗаписи.КоличествоПопыток      = 0;
    МенеджерЗаписи.СледующаяПопытка       = ТекущаяДатаСеанса();
    МенеджерЗаписи.КодОшибки              = КодОшибки;
    МенеджерЗаписи.ТекстОшибки            = Лев(ТекстОшибки, 500);
    МенеджерЗаписи.Статус                 = Перечисления.ekf_СтатусОчередиОтправки.Ожидает;

    МенеджерЗаписи.Записать();

КонецПроцедуры

// Определяет Kafka-топик по типу события.
//
// Параметры:
//  ТипСобытия - Строка - тип события (например "order.created")
//
// Возвращаемое значение:
//  Строка - имя топика Kafka
//
Функция ОпределитьТопик(ТипСобытия)

    Соответствие = Новый Соответствие;
    Соответствие.Вставить("order.created",           "1c.order.created.v1");
    Соответствие.Вставить("order.updated",           "1c.order.updated.v1");
    Соответствие.Вставить("shipment.posted",         "1c.shipment.posted.v1");
    Соответствие.Вставить("shipment.returned",       "1c.shipment.returned.v1");
    Соответствие.Вставить("price.npss-updated",      "1c.price.npss-updated.v1");
    Соответствие.Вставить("price.purchase-changed",  "1c.price.purchase-changed.v1");
    Соответствие.Вставить("client.updated",          "1c.client.updated.v1");
    Соответствие.Вставить("ls.created",              "1c.ls.created.v1");
    Соответствие.Вставить("ls.plan-changed",         "1c.ls.plan-changed.v1");

    Топик = Соответствие.Получить(ТипСобытия);
    Если Топик = Неопределено Тогда
        Возврат "1c.unknown.v1";
    КонецЕсли;

    Возврат Топик;

КонецФункции

// Форматирует число как строку суммы с 2 десятичными: "245.50".
// По ТЗ: все суммы — строки с 2 десятичными знаками.
//
// Параметры:
//  Число - Число - значение для форматирования
//
// Возвращаемое значение:
//  Строка - отформатированная сумма ("245.50")
//
Функция ФорматСуммы(Знач Значение)

    Если НЕ ЗначениеЗаполнено(Значение) Тогда
        Возврат "0.00";
    КонецЕсли;

    Возврат Формат(Значение, "ЧДЦ=2; ЧРД=.; ЧРГ=; ЧГ=0");

КонецФункции

// Форматирует число как строку без десятичных: "100".
//
// Параметры:
//  Значение      - Число - значение
//  ДесятичныеЗнаки - Число - количество десятичных знаков (0 = целое)
//
// Возвращаемое значение:
//  Строка - отформатированное число
//
Функция ФорматЧисла(Знач Значение, ДесятичныеЗнаки)

    Если ДесятичныеЗнаки = 0 Тогда
        Возврат Формат(Цел(Значение), "ЧДЦ=0; ЧРГ=; ЧГ=0");
    Иначе
        Возврат Формат(Значение, "ЧДЦ=" + ДесятичныеЗнаки + "; ЧРД=.; ЧРГ=; ЧГ=0");
    КонецЕсли;

КонецФункции

// Форматирует дату в ISO 8601 с часовым поясом МСК (+03:00).
// По ТЗ: все даты — ISO 8601 с +03:00.
