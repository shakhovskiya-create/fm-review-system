////////////////////////////////////////////////////////////////////////////////
// HTTP-сервис: ekf_КоллбэкРентабельности
// КорневойURL: profitability/api/v1
// Шаблон URL: /commands (POST)
//
// Принимает входящие команды от NiFi (Kafka -> NiFi -> HTTP POST -> 1С):
//   - cmd.approval.result.v1  (результат согласования)
//   - cmd.sanction.applied.v1 (применение санкции)
//   - cmd.block.shipment.v1   (блокировка отгрузки)
//
// ТЗ: docs/tz-1c-kafka-integration.md, секция 4
// Задача: EKFLAB-519
// Автор: Шаховский А.С.
////////////////////////////////////////////////////////////////////////////////

// Обработчик HTTP POST /profitability/api/v1/commands
//
// Параметры:
//  Запрос - HTTPСервисЗапрос - входящий HTTP-запрос
//
// Возвращаемое значение:
//  HTTPСервисОтвет - результат обработки
//
Функция ОбработатьКоманду(Запрос) Экспорт

    // 1. Аутентификация: проверка API key
    APIКлюч = Запрос.Заголовки.Получить("X-Api-Key");
    ОжидаемыйКлюч = Константы.ekf_КоллбэкAPIКлюч.Получить();

    Если НЕ ЗначениеЗаполнено(APIКлюч) ИЛИ APIКлюч <> ОжидаемыйКлюч Тогда
        Возврат СоздатьОтвет(401, Новый Структура("error", "Unauthorized: invalid or missing X-Api-Key"));
    КонецЕсли;

    // 2. Проверка метода
    Если ВРег(Запрос.HTTPМетод) <> "POST" Тогда
        Возврат СоздатьОтвет(405, Новый Структура("error", "Method Not Allowed"));
    КонецЕсли;

    // 3. Парсинг JSON body
    ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

    Если НЕ ЗначениеЗаполнено(ТелоЗапроса) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Empty request body"));
    КонецЕсли;

    Попытка
        ДанныеКоманды = ekf_ИнтеграцияСервер.JSONВСоответствие(ТелоЗапроса);
    Исключение
        Возврат СоздатьОтвет(400, Новый Структура("error", "Invalid JSON: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
    КонецПопытки;

    // 4. Извлекаем обязательные поля
    ИдКоманды  = ДанныеКоманды.Получить("command_id");
    ТипКоманды = ДанныеКоманды.Получить("command_type");

    Если НЕ ЗначениеЗаполнено(ИдКоманды) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Missing required field: command_id"));
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ТипКоманды) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Missing required field: command_type"));
    КонецЕсли;

    // 5. Дедупликация: проверяем command_id
    Если КомандаУжеОбработана(ИдКоманды) Тогда
        Возврат СоздатьОтвет(200, Новый Структура("status,message", "ok", "Already processed (idempotent)"));
    КонецЕсли;

    // 6. Маршрутизация по command_type
    Попытка
        Если ТипКоманды = "approval.result" Тогда
            ekf_ИнтеграцияКомандыСервер.ОбработатьКомандуСогласования(ДанныеКоманды);
            ЗаписатьОбработаннуюКоманду(ИдКоманды, "approval", "ok");

        ИначеЕсли ТипКоманды = "sanction.applied" Тогда
            ekf_ИнтеграцияКомандыСервер.ОбработатьКомандуСанкции(ДанныеКоманды);
            ЗаписатьОбработаннуюКоманду(ИдКоманды, "sanction", "ok");

        ИначеЕсли ТипКоманды = "block.shipment" Тогда
            ekf_ИнтеграцияКомандыСервер.ОбработатьКомандуБлокировки(ДанныеКоманды);
            ЗаписатьОбработаннуюКоманду(ИдКоманды, "block", "ok");

        Иначе
            Возврат СоздатьОтвет(400,
                Новый Структура("error", "Unknown command_type: " + ТипКоманды));
        КонецЕсли;
    Исключение
        ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());

        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.ОбработкаКоманды",
            УровеньЖурналаРегистрации.Ошибка, , ,
            СтрШаблон("Ошибка обработки команды: id=%1, тип=%2. %3",
                ИдКоманды, ТипКоманды, ТекстОшибки));

        ЗаписатьОбработаннуюКоманду(ИдКоманды, ТипКоманды, "error");

        Возврат СоздатьОтвет(500,
            Новый Структура("error", "Internal error processing command"));
    КонецПопытки;

    ЗаписьЖурналаРегистрации(
        "ekf_Интеграция.ОбработкаКоманды",
        УровеньЖурналаРегистрации.Информация, , ,
        СтрШаблон("Команда обработана: id=%1, тип=%2", ИдКоманды, ТипКоманды));

    Возврат СоздатьОтвет(200, Новый Структура("status", "ok"));

КонецФункции

////////////////////////////////////////////////////////////////////////////////
// Служебные процедуры HTTP-сервиса
////////////////////////////////////////////////////////////////////////////////

// Проверяет, была ли команда уже обработана (дедупликация).
//
// Параметры:
//  ИдКоманды - Строка - command_id (UUID)
//
// Возвращаемое значение:
//  Булево - Истина, если команда уже обработана
//
Функция КомандаУжеОбработана(ИдКоманды)

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   1 КАК Поле1
        |ИЗ
        |   РегистрСведений.ekf_ОбработанныеКоманды КАК Команды
        |ГДЕ
        |   Команды.ИдентификаторКоманды = &ИдКоманды";
    Запрос.УстановитьПараметр("ИдКоманды", ИдКоманды);

    Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции

// Записывает факт обработки команды для дедупликации.
//
// Параметры:
//  ИдКоманды   - Строка - command_id (UUID)
//  ТипКоманды  - Строка - "approval" / "sanction" / "block"
//  Результат   - Строка - "ok" / "error"
//
Процедура ЗаписатьОбработаннуюКоманду(ИдКоманды, ТипКоманды, Результат)

    МенеджерЗаписи = РегистрыСведений.ekf_ОбработанныеКоманды.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторКоманды = ИдКоманды;
    МенеджерЗаписи.ДатаОбработки        = ТекущаяДатаСеанса();
    МенеджерЗаписи.ТипКоманды           = ТипКоманды;
    МенеджерЗаписи.Результат            = Результат;
    МенеджерЗаписи.Записать();

КонецПроцедуры

// Создает HTTP-ответ с JSON-телом.
//
// Параметры:
//  КодСостояния - Число - HTTP код (200, 400, 401, 500)
//  СтруктураТела - Структура - данные для JSON-ответа
//
// Возвращаемое значение:
//  HTTPСервисОтвет - готовый ответ
//
Функция СоздатьОтвет(КодСостояния, СтруктураТела)

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(
        ekf_ИнтеграцияСервер.СтруктуруВJSON(СтруктураТела),
        КодировкаТекста.UTF8);

    Возврат Ответ;

КонецФункции

