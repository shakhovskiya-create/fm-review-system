////////////////////////////////////////////////////////////////////////////////
// Общий модуль: ekf_ИнтеграцияКомандыСервер
// Контекст: Сервер
//
// Назначение: бизнес-логика обработки входящих команд от profitability-service.
// Каждая команда обрабатывается в отдельной транзакции с блокировкой данных.
//
// ТЗ: docs/tz-1c-kafka-integration.md, секция 4 (4.1, 4.2, 4.3)
// Задача: EKFLAB-519
// Автор: Шаховский А.С.
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Обрабатывает команду "Результат согласования" (cmd.approval.result.v1).
// Обновляет статус документа реализации или заказа.
//
// По ТЗ 4.1:
//  decision: approved | rejected | correction_required
//  Действие: обновить статус документа, записать комментарий
//
// Параметры:
//  ДанныеКоманды - Соответствие - данные команды (command_id, shipment_id, decision, и т.д.)
//
Процедура ОбработатьКомандуСогласования(ДанныеКоманды) Экспорт

    ИдОтгрузки    = ДанныеКоманды.Получить("shipment_id");
    ИдЛС          = ДанныеКоманды.Получить("local_estimate_id");
    Решение        = ДанныеКоманды.Получить("decision");
    ИдОдобрителя   = ДанныеКоманды.Получить("approver_id");
    ИмяОдобрителя  = ДанныеКоманды.Получить("approver_name");
    УровеньСогл    = ДанныеКоманды.Получить("approval_level");
    Комментарий    = ДанныеКоманды.Получить("comment");

    Если НЕ ЗначениеЗаполнено(Решение) Тогда
        ВызватьИсключение "Поле decision обязательно в команде approval.result";
    КонецЕсли;

    // Логируем входящую команду
    ЗаписьЖурналаРегистрации(
        "ekf_Интеграция.Согласование",
        УровеньЖурналаРегистрации.Информация, , ,
        СтрШаблон("Получен результат согласования: shipment=%1, decision=%2, approver=%3, level=%4",
            ИдОтгрузки, Решение, ИмяОдобрителя, УровеньСогл));

    // Находим документ реализации по UUID
    // Примечание: в типовой УТ 10.2 поиск по UUID осуществляется через
    // РегистрыСведений или запрос по ключевому полю (номер документа)
    Если ЗначениеЗаполнено(ИдОтгрузки) Тогда
        ДокументСсылка = НайтиДокументПоИд(ИдОтгрузки, "РеализацияТоваровИУслуг");
    Иначе
        ДокументСсылка = Неопределено;
    КонецЕсли;

    // Записываем результат согласования в доп. реквизиты документа
    Если ЗначениеЗаполнено(ДокументСсылка) Тогда

        НачатьТранзакцию();
        Попытка
            БлокировкаДанных = Новый БлокировкаДанных;
            ЭлементБлокировки = БлокировкаДанных.Добавить("Документ.РеализацияТоваровИУслуг");
            ЭлементБлокировки.УстановитьЗначение("Ссылка", ДокументСсылка);
            ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
            БлокировкаДанных.Заблокировать();

            ДокументОбъект = ДокументСсылка.ПолучитьОбъект();

            // Записываем результат в доп. реквизиты расширения
            Попытка
                ДокументОбъект.ekf_СтатусСогласования = Решение;
                ДокументОбъект.ekf_КомментарийСогласования = Лев(
                    СтрШаблон("%1 (%2, %3): %4", ИмяОдобрителя, УровеньСогл,
                        Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy HH:mm"), Комментарий), 500);
            Исключение
                // Доп. реквизиты могут отсутствовать — логируем
                ЗаписьЖурналаРегистрации(
                    "ekf_Интеграция.Согласование",
                    УровеньЖурналаРегистрации.Предупреждение, , ,
                    "Доп. реквизиты ekf_СтатусСогласования отсутствуют. Результат записан только в журнал.");
            КонецПопытки;

            // Если decision = "rejected" — можно распровести документ
            Если Решение = "rejected" Тогда
                ЗаписьЖурналаРегистрации(
                    "ekf_Интеграция.Согласование",
                    УровеньЖурналаРегистрации.Предупреждение, , ДокументСсылка,
                    СтрШаблон("Отгрузка ОТКЛОНЕНА: %1. Причина: %2", ДокументСсылка, Комментарий));
            КонецЕсли;

            ДокументОбъект.Записать();

            ЗафиксироватьТранзакцию();
        Исключение
            ОтменитьТранзакцию();
            ВызватьИсключение;
        КонецПопытки;

    Иначе
        // Документ не найден — логируем предупреждение
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.Согласование",
            УровеньЖурналаРегистрации.Предупреждение, , ,
            СтрШаблон("Документ реализации не найден по shipment_id=%1. Результат сохранен только в журнале.",
                ИдОтгрузки));
    КонецЕсли;

КонецПроцедуры

// Обрабатывает команду "Применение санкции" (cmd.sanction.applied.v1).
// Записывает информацию о санкции в карточку контрагента.
// При sanction_type = "block" — запрещает создание новых заказов.
//
// По ТЗ 4.2:
//  sanction_type: warning | limit_reduction | block
//
// Параметры:
//  ДанныеКоманды - Соответствие - данные команды
//
Процедура ОбработатьКомандуСанкции(ДанныеКоманды) Экспорт

    ИдКлиента     = ДанныеКоманды.Получить("client_id");
    ТипСанкции    = ДанныеКоманды.Получить("sanction_type");
    Причина       = ДанныеКоманды.Получить("reason");
    ДатаНачала    = ДанныеКоманды.Получить("effective_date");
    ДатаОкончания = ДанныеКоманды.Получить("expires_at");

    Если НЕ ЗначениеЗаполнено(ИдКлиента) Тогда
        ВызватьИсключение "Поле client_id обязательно в команде sanction.applied";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ТипСанкции) Тогда
        ВызватьИсключение "Поле sanction_type обязательно в команде sanction.applied";
    КонецЕсли;

    // Логируем
    ЗаписьЖурналаРегистрации(
        "ekf_Интеграция.Санкция",
        УровеньЖурналаРегистрации.Предупреждение, , ,
        СтрШаблон("Применение санкции: client=%1, тип=%2, причина=%3, срок=%4..%5",
            ИдКлиента, ТипСанкции, Причина, ДатаНачала, ДатаОкончания));

    // Находим контрагента
    КонтрагентСсылка = НайтиКонтрагентаПоИд(ИдКлиента);

    Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.Санкция",
            УровеньЖурналаРегистрации.Ошибка, , ,
            СтрШаблон("Контрагент не найден по client_id=%1", ИдКлиента));
        ВызватьИсключение СтрШаблон("Контрагент не найден: %1", ИдКлиента);
    КонецЕсли;

    НачатьТранзакцию();
    Попытка
        БлокировкаДанных = Новый БлокировкаДанных;
        ЭлементБлокировки = БлокировкаДанных.Добавить("Справочник.Контрагенты");
        ЭлементБлокировки.УстановитьЗначение("Ссылка", КонтрагентСсылка);
        ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
        БлокировкаДанных.Заблокировать();

        КонтрагентОбъект = КонтрагентСсылка.ПолучитьОбъект();

        // Записываем санкцию в доп. реквизиты расширения
        Попытка
            КонтрагентОбъект.ekf_ТипСанкции       = ТипСанкции;
            КонтрагентОбъект.ekf_ПричинаСанкции    = Лев(Причина, 500);
            КонтрагентОбъект.ekf_ДатаНачалаСанкции = ПреобразоватьДату(ДатаНачала);
            КонтрагентОбъект.ekf_ДатаОкончанияСанкции = ПреобразоватьДату(ДатаОкончания);

            // При block — устанавливаем признак блокировки
            Если ТипСанкции = "block" Тогда
                КонтрагентОбъект.ekf_ЗаказыЗаблокированы = Истина;
            КонецЕсли;

        Исключение
            ЗаписьЖурналаРегистрации(
                "ekf_Интеграция.Санкция",
                УровеньЖурналаРегистрации.Предупреждение, , ,
                "Доп. реквизиты санкций отсутствуют в контрагенте. Результат записан только в журнал.");
        КонецПопытки;

        КонтрагентОбъект.Записать();

        ЗафиксироватьТранзакцию();
    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;

КонецПроцедуры

// Обрабатывает команду "Блокировка отгрузки" (cmd.block.shipment.v1).
// Запрещает проведение конкретного документа реализации.
//
// По ТЗ 4.3:
//  Действие: запретить проведение документа реализации
//
// Параметры:
//  ДанныеКоманды - Соответствие - данные команды
//
Процедура ОбработатьКомандуБлокировки(ДанныеКоманды) Экспорт

    ИдОтгрузки = ДанныеКоманды.Получить("shipment_id");
    Причина    = ДанныеКоманды.Получить("reason");
    КемЗаблок  = ДанныеКоманды.Получить("blocked_by");

    Если НЕ ЗначениеЗаполнено(ИдОтгрузки) Тогда
        ВызватьИсключение "Поле shipment_id обязательно в команде block.shipment";
    КонецЕсли;

    // Логируем
    ЗаписьЖурналаРегистрации(
        "ekf_Интеграция.БлокировкаОтгрузки",
        УровеньЖурналаРегистрации.Предупреждение, , ,
        СтрШаблон("Блокировка отгрузки: shipment=%1, причина=%2, blocked_by=%3",
            ИдОтгрузки, Причина, КемЗаблок));

    // Находим документ реализации
    ДокументСсылка = НайтиДокументПоИд(ИдОтгрузки, "РеализацияТоваровИУслуг");

    Если НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.БлокировкаОтгрузки",
            УровеньЖурналаРегистрации.Ошибка, , ,
            СтрШаблон("Документ реализации не найден по shipment_id=%1", ИдОтгрузки));
        ВызватьИсключение СтрШаблон("Документ реализации не найден: %1", ИдОтгрузки);
    КонецЕсли;

    НачатьТранзакцию();
    Попытка
        БлокировкаДанных = Новый БлокировкаДанных;
        ЭлементБлокировки = БлокировкаДанных.Добавить("Документ.РеализацияТоваровИУслуг");
        ЭлементБлокировки.УстановитьЗначение("Ссылка", ДокументСсылка);
        ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
        БлокировкаДанных.Заблокировать();

        ДокументОбъект = ДокументСсылка.ПолучитьОбъект();

        // Устанавливаем признак блокировки
        Попытка
            ДокументОбъект.ekf_ОтгрузкаЗаблокирована = Истина;
            ДокументОбъект.ekf_ПричинаБлокировки = Лев(Причина, 500);
        Исключение
            ЗаписьЖурналаРегистрации(
                "ekf_Интеграция.БлокировкаОтгрузки",
                УровеньЖурналаРегистрации.Предупреждение, , ,
                "Доп. реквизиты блокировки отсутствуют. Результат записан только в журнал.");
        КонецПопытки;

        // Если документ проведен — распроводим его
        Если ДокументОбъект.Проведен Тогда
            ЗаписьЖурналаРегистрации(
                "ekf_Интеграция.БлокировкаОтгрузки",
                УровеньЖурналаРегистрации.Предупреждение, , ДокументСсылка,
                СтрШаблон("Отгрузка распроведена по команде блокировки: %1. Причина: %2",
                    ДокументСсылка, Причина));
            ДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
        Иначе
            ДокументОбъект.Записать();
        КонецЕсли;

        ЗафиксироватьТранзакцию();
    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Находит документ по UUID (УникальныйИдентификатор).
//
// Параметры:
//  ИдДокумента  - Строка - UUID документа
//  ИмяДокумента - Строка - имя метаданных ("РеализацияТоваровИУслуг")
//
// Возвращаемое значение:
//  ДокументСсылка / Неопределено - найденный документ или Неопределено
//
Функция НайтиДокументПоИд(ИдДокумента, ИмяДокумента)

    Попытка
        УИД = Новый УникальныйИдентификатор(ИдДокумента);
        ДокументСсылка = Документы[ИмяДокумента].ПолучитьСсылку(УИД);

        // Проверяем что документ существует
        Если ДокументСсылка.Пустая() ИЛИ НЕ ЗначениеЗаполнено(ДокументСсылка) Тогда
            Возврат Неопределено;
        КонецЕсли;

        // Проверяем что документ реально существует в базе
        Запрос = Новый Запрос;
        Запрос.Текст = СтрШаблон(
            "ВЫБРАТЬ ПЕРВЫЕ 1
            |   Док.Ссылка КАК Ссылка
            |ИЗ
            |   Документ.%1 КАК Док
            |ГДЕ
            |   Док.Ссылка = &Ссылка", ИмяДокумента);
        Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

        Если Запрос.Выполнить().Пустой() Тогда
            Возврат Неопределено;
        КонецЕсли;

        Возврат ДокументСсылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Находит контрагента по UUID.
//
// Параметры:
//  ИдКлиента - Строка - UUID контрагента
//
// Возвращаемое значение:
//  СправочникСсылка.Контрагенты / Неопределено
//
Функция НайтиКонтрагентаПоИд(ИдКлиента)

    Попытка
        УИД = Новый УникальныйИдентификатор(ИдКлиента);
        КонтрагентСсылка = Справочники.Контрагенты.ПолучитьСсылку(УИД);

        Если КонтрагентСсылка.Пустая() ИЛИ НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
            Возврат Неопределено;
        КонецЕсли;

        // Проверяем существование в базе
        Запрос = Новый Запрос;
        Запрос.Текст =
            "ВЫБРАТЬ ПЕРВЫЕ 1
            |   Контр.Ссылка КАК Ссылка
            |ИЗ
            |   Справочник.Контрагенты КАК Контр
            |ГДЕ
            |   Контр.Ссылка = &Ссылка";
        Запрос.УстановитьПараметр("Ссылка", КонтрагентСсылка);

        Если Запрос.Выполнить().Пустой() Тогда
            Возврат Неопределено;
        КонецЕсли;

        Возврат КонтрагентСсылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Преобразует строку даты ISO в тип Дата.
//
// Параметры:
//  СтрокаДаты - Строка - дата в формате ISO 8601 ("2026-03-15" или "2026-03-15T23:59:59+03:00")
//
// Возвращаемое значение:
//  Дата - преобразованная дата (или пустая дата при ошибке)
//
Функция ПреобразоватьДату(СтрокаДаты)

    Если НЕ ЗначениеЗаполнено(СтрокаДаты) Тогда
        Возврат '00010101';
    КонецЕсли;

    Попытка
        // Пробуем XMLЗначение (поддерживает ISO 8601)
        Возврат XMLЗначение(Тип("Дата"), Лев(СтрокаДаты, 19));
    Исключение
        // Пробуем простой формат yyyy-MM-dd
        Попытка
            Возврат Дата(Лев(СтрокаДаты, 4) + Сред(СтрокаДаты, 6, 2) + Сред(СтрокаДаты, 9, 2));
        Исключение
            Возврат '00010101';
        КонецПопытки;
    КонецПопытки;

КонецФункции

#КонецОбласти
