// Общий модуль: ekf_ИнтеграцияФоновые
// Контекст: Сервер
//
// Назначение: фоновые задания интеграции:
//   1. Обработка очереди повторной отправки (каждые 60 сек, batch 50)
//   2. Очистка отправленных/устаревших событий (ежедневно 03:00)
//   3. Очистка старых записей дедупликации команд (ежедневно 03:00)
//
// ТЗ: docs/tz-1c-kafka-integration.md, секция 5.3 (гарантии доставки)
// Задача: EKFLAB-518
// Автор: Шаховский А.С.
// Изменения: EKFLAB-522 — HIGH-001 (перечисление статусов), HIGH-002 (кешированные настройки),
//            HIGH-004 (функциональная опция)

#Область ПрограммныйИнтерфейс

// Обрабатывает очередь повторной отправки событий.
// Вызывается регламентным заданием ekf_ОбработкаОчередиОтправки (каждые 60 сек).
// Берет batch из 50 записей со статусом "pending" и СледующаяПопытка <= текущее время.
//
Процедура ОбработатьОчередьОтправки() Экспорт

    // Проверка kill switch (через кешированный модуль, HIGH-002)
    Если НЕ ekf_ИнтеграцияНастройкиПовтИспСервер.ИнтеграцияАктивна() Тогда
        Возврат;
    КонецЕсли;

    МаксПопыток = ekf_ИнтеграцияНастройкиПовтИспСервер.МаксПопытокОтправки();

    // Выбираем batch записей для отправки
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 50
        |   Очередь.ИдентификаторСообщения КАК ИдентификаторСообщения,
        |   Очередь.ТипСобытия КАК ТипСобытия,
        |   Очередь.ТелоСообщения КАК ТелоСообщения,
        |   Очередь.ИдКорреляции КАК ИдКорреляции,
        |   Очередь.КоличествоПопыток КАК КоличествоПопыток
        |ИЗ
        |   РегистрСведений.ekf_ОчередьОтправкиСобытий КАК Очередь
        |ГДЕ
        |   Очередь.Статус = &СтатусОжидает
        |   И Очередь.СледующаяПопытка <= &ТекущаяДата
        |УПОРЯДОЧИТЬ ПО
        |   Очередь.ДатаСоздания";
    Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
    Запрос.УстановитьПараметр("СтатусОжидает", Перечисления.ekf_СтатусОчередиОтправки.Ожидает);

    Результат = Запрос.Выполнить();
    Если Результат.Пустой() Тогда
        Возврат;
    КонецЕсли;

    КоличествоУспешных = 0; // Счетчик успешных отправок
    КоличествоОшибок   = 0; // Счетчик ошибок

    Выборка = Результат.Выбрать();
    Пока Выборка.Следующий() Цикл

        ИдСообщения     = Строка(Выборка.ИдентификаторСообщения);
        НомерПопытки    = Выборка.КоличествоПопыток + 1;
        ТелоJSON        = Выборка.ТелоСообщения.Получить(); // извлекаем из ХранилищеЗначения
        ИдКорреляции    = Выборка.ИдКорреляции;

        // Пометить как "Отправляется" (защита от параллельного выполнения, HIGH-001)
        ОбновитьСтатусЗаписи(Выборка.ИдентификаторСообщения, Перечисления.ekf_СтатусОчередиОтправки.Отправляется);

        // Попытка отправки
        Успех = ekf_ИнтеграцияСервер.ОтправитьИзОчереди(ИдСообщения, ТелоJSON, ИдКорреляции);

        Если Успех Тогда
            // Удаляем успешно отправленную запись
            УдалитьЗаписьИзОчереди(Выборка.ИдентификаторСообщения);
            КоличествоУспешных = КоличествоУспешных + 1;
        Иначе
            // Обновляем запись: увеличиваем счетчик, рассчитываем следующую попытку
            Если НомерПопытки >= МаксПопыток Тогда
                // Максимум попыток исчерпан — помечаем как Истёк (HIGH-001)
                ОбновитьЗаписьПослеОшибки(Выборка.ИдентификаторСообщения, НомерПопытки,
                    Перечисления.ekf_СтатусОчередиОтправки.Истёк);
                ЗаписьЖурналаРегистрации(
                    "ekf_Интеграция.ОчередьОтправки",
                    УровеньЖурналаРегистрации.Ошибка, , ,
                    СтрШаблон("Сообщение истекло после %1 попыток: id=%2, тип=%3",
                        МаксПопыток, ИдСообщения, Выборка.ТипСобытия));
            Иначе
                ОбновитьЗаписьПослеОшибки(Выборка.ИдентификаторСообщения, НомерПопытки,
                    Перечисления.ekf_СтатусОчередиОтправки.Ожидает);
            КонецЕсли;
            КоличествоОшибок = КоличествоОшибок + 1;
        КонецЕсли;

    КонецЦикла;

    // Логируем итог если было что обрабатывать
    Если КоличествоУспешных + КоличествоОшибок > 0 Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.ОчередьОтправки",
            УровеньЖурналаРегистрации.Информация, , ,
            СтрШаблон("Обработка очереди: успешно=%1, ошибок=%2",
                КоличествоУспешных, КоличествоОшибок));
    КонецЕсли;

КонецПроцедуры

// Очищает старые записи из очереди отправки.
// Удаляет записи старше 7 дней (успешно отправленные уже удалены при отправке).
// Вызывается регламентным заданием ekf_ОчисткаСтарыхЗаписей (ежедневно 03:00).
//
Процедура ОчиститьОтправленныеСобытия() Экспорт

    ПороговаяДата = ТекущаяДатаСеанса() - 7 * 86400; // 7 дней

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Очередь.ИдентификаторСообщения КАК ИдентификаторСообщения,
        |   Очередь.Статус КАК Статус
        |ИЗ
        |   РегистрСведений.ekf_ОчередьОтправкиСобытий КАК Очередь
        |ГДЕ
        |   Очередь.ДатаСоздания < &ПороговаяДата
        |   И Очередь.Статус = &СтатусИстёк";
    Запрос.УстановитьПараметр("ПороговаяДата", ПороговаяДата);
    Запрос.УстановитьПараметр("СтатусИстёк", Перечисления.ekf_СтатусОчередиОтправки.Истёк);

    Результат = Запрос.Выполнить();
    Если Результат.Пустой() Тогда
        Возврат;
    КонецЕсли;

    КоличествоУдаленных = 0; // Счетчик

    Выборка = Результат.Выбрать();
    Пока Выборка.Следующий() Цикл
        УдалитьЗаписьИзОчереди(Выборка.ИдентификаторСообщения);
        КоличествоУдаленных = КоличествоУдаленных + 1;
    КонецЦикла;

    Если КоличествоУдаленных > 0 Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.Очистка",
            УровеньЖурналаРегистрации.Информация, , ,
            СтрШаблон("Удалено %1 устаревших записей из очереди отправки", КоличествоУдаленных));
    КонецЕсли;

КонецПроцедуры

// Очищает старые записи дедупликации обработанных команд.
// Удаляет записи старше 30 дней.
// Вызывается вместе с ОчиститьОтправленныеСобытия.
//
Процедура ОчиститьСтарыеКоманды() Экспорт

    ПороговаяДата = ТекущаяДатаСеанса() - 30 * 86400; // 30 дней

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Команды.ИдентификаторКоманды КАК ИдентификаторКоманды
        |ИЗ
        |   РегистрСведений.ekf_ОбработанныеКоманды КАК Команды
        |ГДЕ
        |   Команды.ДатаОбработки < &ПороговаяДата";
    Запрос.УстановитьПараметр("ПороговаяДата", ПороговаяДата);

    Результат = Запрос.Выполнить();
    Если Результат.Пустой() Тогда
        Возврат;
    КонецЕсли;

    КоличествоУдаленных = 0; // Счетчик

    Выборка = Результат.Выбрать();
    Пока Выборка.Следующий() Цикл
        МенеджерЗаписи = РегистрыСведений.ekf_ОбработанныеКоманды.СоздатьМенеджерЗаписи();
        МенеджерЗаписи.ИдентификаторКоманды = Выборка.ИдентификаторКоманды;
        МенеджерЗаписи.Удалить();
        КоличествоУдаленных = КоличествоУдаленных + 1;
    КонецЦикла;

    Если КоличествоУдаленных > 0 Тогда
        ЗаписьЖурналаРегистрации(
            "ekf_Интеграция.Очистка",
            УровеньЖурналаРегистрации.Информация, , ,
            СтрШаблон("Удалено %1 старых записей дедупликации команд", КоличествоУдаленных));
    КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обновляет статус записи в очереди.
//
// Параметры:
//  ИдентификаторСообщения - УникальныйИдентификатор - UUID сообщения
//  НовыйСтатус           - ПеречислениеСсылка.ekf_СтатусОчередиОтправки - новый статус
//
Процедура ОбновитьСтатусЗаписи(ИдентификаторСообщения, НовыйСтатус)

    МенеджерЗаписи = РегистрыСведений.ekf_ОчередьОтправкиСобытий.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторСообщения = ИдентификаторСообщения;
    МенеджерЗаписи.Прочитать();
    МенеджерЗаписи.Статус = НовыйСтатус;
    МенеджерЗаписи.Записать();

КонецПроцедуры

// Обновляет запись после неудачной попытки отправки.
//
// Параметры:
//  ИдентификаторСообщения - УникальныйИдентификатор - UUID сообщения
//  НомерПопытки           - Число - текущий номер попытки
//  НовыйСтатус           - ПеречислениеСсылка.ekf_СтатусОчередиОтправки - Ожидает или Истёк
//
Процедура ОбновитьЗаписьПослеОшибки(ИдентификаторСообщения, НомерПопытки, НовыйСтатус)

    МенеджерЗаписи = РегистрыСведений.ekf_ОчередьОтправкиСобытий.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторСообщения = ИдентификаторСообщения;
    МенеджерЗаписи.Прочитать();

    МенеджерЗаписи.КоличествоПопыток = НомерПопытки;
    МенеджерЗаписи.Статус             = НовыйСтатус;

    Если НовыйСтатус = Перечисления.ekf_СтатусОчередиОтправки.Ожидает Тогда
        МенеджерЗаписи.СледующаяПопытка = ekf_ИнтеграцияСервер.РассчитатьСледующуюПопытку(НомерПопытки);
    КонецЕсли;

    МенеджерЗаписи.Записать();

КонецПроцедуры

// Удаляет запись из очереди.
//
// Параметры:
//  ИдентификаторСообщения - УникальныйИдентификатор - UUID сообщения
//
Процедура УдалитьЗаписьИзОчереди(ИдентификаторСообщения)

    МенеджерЗаписи = РегистрыСведений.ekf_ОчередьОтправкиСобытий.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторСообщения = ИдентификаторСообщения;
    МенеджерЗаписи.Удалить();

КонецПроцедуры

#КонецОбласти
