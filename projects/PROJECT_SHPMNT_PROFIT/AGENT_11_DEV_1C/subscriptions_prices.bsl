// Подписка на событие: ekf_ПриЗаписиУстановкаЦен
// Источник: Документ.УстановкаЦенНоменклатуры
// Событие: ПриЗаписи
//
// Генерирует события:
//   - "price.npss-updated" (1c.price.npss-updated.v1) — изменение НПСС
//   - "price.purchase-changed" (1c.price.purchase-changed.v1) — изменение закупочной цены
//
// ТЗ: docs/tz-1c-kafka-integration.md, секции 3.5, 3.6
// Задача: EKFLAB-518
// Автор: Шаховский А.С.
// Изменения: EKFLAB-522 — HIGH-004 (функциональная опция)

// Обработчик подписки ПриЗаписи документа "Установка цен номенклатуры".
// Анализирует строки документа и определяет тип ценового события.
//
// Параметры:
//  Источник - ДокументОбъект.УстановкаЦенНоменклатуры - записываемый документ
//  Отказ    - Булево - флаг отказа от записи
//
Процедура ПриЗаписиУстановкаЦен(Источник, Отказ) Экспорт

    // Не отправлять событие, если запись уже отменена
    Если Отказ Тогда
        Возврат;
    КонецЕсли;

    // HIGH-004: Проверка функциональной опции (привязана к kill switch)
    Если НЕ ПолучитьФункциональнуюОпцию("ekf_ИнтеграцияРентабельности") Тогда
        Возврат;
    КонецЕсли;

    // Обрабатываем каждую строку документа установки цен
    Для Каждого СтрокаЦены Из Источник.Товары Цикл

        Если НЕ ЗначениеЗаполнено(СтрокаЦены.Номенклатура) Тогда
            Продолжить;
        КонецЕсли;

        // Определяем тип цены
        ТипЦены = Строка(СтрокаЦены.ТипЦен);

        Если ВРег(ТипЦены) = "НПСС" ИЛИ ВРег(ТипЦены) = "NPSS" Тогда

            // НПСС — событие price.npss-updated
            ОбработатьИзменениеНПСС(СтрокаЦены, Источник);

        ИначеЕсли ВРег(ТипЦены) = "ЗАКУПОЧНАЯ" ИЛИ ВРег(ТипЦены) = "ЗАКУПОЧНАЯ ЦЕНА" Тогда

            // Закупочная цена — событие price.purchase-changed
            ОбработатьИзменениеЗакупочнойЦены(СтрокаЦены, Источник);

        КонецЕсли;

    КонецЦикла;

КонецПроцедуры

// Обрабатывает изменение НПСС для одной позиции.
//
// Параметры:
//  СтрокаЦены     - СтрокаТабличнойЧасти - строка документа "Установка цен"
//  ДокументОбъект - ДокументОбъект.УстановкаЦенНоменклатуры - документ
//
Процедура ОбработатьИзменениеНПСС(СтрокаЦены, ДокументОбъект)

    // Получаем текущую (старую) НПСС из регистра
    СтараяНПСС = ekf_ИнтеграцияСервер.ПолучитьНПСС(
        СтрокаЦены.Номенклатура, ДокументОбъект.Дата);

    НоваяНПСС = СтрокаЦены.Цена;

    // Не отправлять если цена не изменилась
    Если СтараяНПСС = НоваяНПСС Тогда
        Возврат;
    КонецЕсли;

    // Получаем компоненты НПСС (закупочная, логистика, накладные)
    // В типовой УТ 10.2 эти данные могут быть в разных регистрах.
    // Здесь используем доступные данные, недоступные — передаём как 0.
    ЦенаЗакупки      = 0;
    ЗатратыЛогистика = 0;
    ЗатратыНакладные = 0;

    Попытка
        // Попытка получить закупочную цену
        ЦенаЗакупки = ПолучитьЗакупочнуюЦену(СтрокаЦены.Номенклатура, ДокументОбъект.Дата);
        ЗатратыЛогистика = НоваяНПСС - ЦенаЗакупки - ЗатратыНакладные;
        Если ЗатратыЛогистика < 0 Тогда
            ЗатратыЛогистика = 0;
        КонецЕсли;
    Исключение
        // Компоненты недоступны — передаём нули
    КонецПопытки;

    // Определяем триггер
    Триггер = ОпределитьТриггерНПСС(ДокументОбъект);

    ДанныеСобытия = ekf_ИнтеграцияСервер.СформироватьДанныеНПСС(
        СтрокаЦены.Номенклатура,
        СтараяНПСС, НоваяНПСС,
        ЦенаЗакупки, ЗатратыЛогистика, ЗатратыНакладные,
        "weighted_average",
        Триггер);

    ekf_ИнтеграцияСервер.ОтправитьСобытие("price.npss-updated", ДанныеСобытия);

КонецПроцедуры

// Обрабатывает изменение закупочной цены для одной позиции.
//
// Параметры:
//  СтрокаЦены     - СтрокаТабличнойЧасти - строка документа "Установка цен"
//  ДокументОбъект - ДокументОбъект.УстановкаЦенНоменклатуры - документ
//
Процедура ОбработатьИзменениеЗакупочнойЦены(СтрокаЦены, ДокументОбъект)

    // Получаем текущую (старую) закупочную цену
    СтараяЦена = ПолучитьЗакупочнуюЦену(СтрокаЦены.Номенклатура, ДокументОбъект.Дата);

    НоваяЦена = СтрокаЦены.Цена;

    // Не отправлять если цена не изменилась
    Если СтараяЦена = НоваяЦена Тогда
        Возврат;
    КонецЕсли;

    // Определяем поставщика (если есть в документе)
    Поставщик = "";
    Попытка
        Если ЗначениеЗаполнено(ДокументОбъект.Контрагент) Тогда
            Поставщик = Строка(ДокументОбъект.Контрагент);
        КонецЕсли;
    Исключение
        // Реквизит Контрагент может отсутствовать
    КонецПопытки;

    // Дата действия = дата документа
    ДатаДействия = ДокументОбъект.Дата;

    ДанныеСобытия = ekf_ИнтеграцияСервер.СформироватьДанныеЗакупочнойЦены(
        СтрокаЦены.Номенклатура,
        СтараяЦена, НоваяЦена,
        Поставщик, ДатаДействия);

    ekf_ИнтеграцияСервер.ОтправитьСобытие("price.purchase-changed", ДанныеСобытия);

КонецПроцедуры

// Получает закупочную цену номенклатуры на дату.
//
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура - товар
//  ДатаСреза    - Дата - дата среза
//
// Возвращаемое значение:
//  Число - закупочная цена (0 если не найдена)
//
Функция ПолучитьЗакупочнуюЦену(Номенклатура, ДатаСреза)

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   ЦеныСрез.Цена КАК Цена
        |ИЗ
        |   РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, Номенклатура = &Номенклатура
        |       И ТипЦен = &ТипЦен) КАК ЦеныСрез";
    Запрос.УстановитьПараметр("Дата",         ДатаСреза);
    Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

    Попытка
        ТипЦенЗакупочная = Справочники.ТипыЦенНоменклатуры.НайтиПоНаименованию("Закупочная");
        Запрос.УстановитьПараметр("ТипЦен", ТипЦенЗакупочная);
    Исключение
        Возврат 0;
    КонецПопытки;

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Цена;
    КонецЕсли;

    Возврат 0;

КонецФункции

// Определяет триггер пересчета НПСС.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.УстановкаЦенНоменклатуры - документ
//
// Возвращаемое значение:
//  Строка - "planned" / "exchange_rate" / "purchase_price"
//
Функция ОпределитьТриггерНПСС(ДокументОбъект)

    // Триггер определяется по комментарию документа или доп. реквизиту
    Попытка
        Комментарий = ВРег(СокрЛП(ДокументОбъект.Комментарий));
        Если СтрНайти(Комментарий, "КУРС") > 0 Тогда
            Возврат "exchange_rate";
        ИначеЕсли СтрНайти(Комментарий, "ЗАКУПК") > 0 Тогда
            Возврат "purchase_price";
        КонецЕсли;
    Исключение
        // Комментарий может отсутствовать
    КонецПопытки;

    Возврат "planned";

КонецФункции
